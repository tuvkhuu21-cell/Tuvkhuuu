generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  customer
  driver
  manager
  admin
}

enum OrderStatus {
  Pending
  Assigned
  PickedUp   @map("Picked Up")
  OnTheWay   @map("On The Way")
  Delivered
}

enum PaymentStatus {
  Pending
  Paid
  Failed
  Refunded
  CashOnDelivery
}

enum PaymentMethod {
  Card
  CashOnDelivery
  Manual
}

model User {
  id            String         @id @db.Char(36)
  name          String         @db.VarChar(120)
  email         String         @unique @db.VarChar(190)
  passwordHash  String         @map("password_hash") @db.VarChar(255)
  role          UserRole
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  refreshTokens RefreshToken[]
  driverProfile Driver?
  customerOrders Order[]       @relation("OrderCustomer")
  orderEvents   OrderEvent[]
  payments      Payment[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @db.Char(36)
  userId    String   @map("user_id") @db.Char(36)
  tokenHash String   @map("token_hash") @db.VarChar(255)
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Driver {
  id           String   @id @db.Char(36)
  userId       String   @unique @map("user_id") @db.Char(36)
  phone        String?  @db.VarChar(40)
  isAvailable  Boolean  @default(true) @map("is_available")
  currentLat   Decimal? @map("current_lat") @db.Decimal(10, 7)
  currentLng   Decimal? @map("current_lng") @db.Decimal(10, 7)
  lastSeenAt   DateTime? @map("last_seen_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders       Order[]
  locations    DriverLocation[]

  @@index([isAvailable], map: "idx_drivers_is_available")
  @@index([currentLat], map: "idx_drivers_current_lat")
  @@index([currentLng], map: "idx_drivers_current_lng")
  @@map("drivers")
}

model Order {
  id               String         @id @db.Char(36)
  customerId       String         @map("customer_id") @db.Char(36)
  driverId         String?        @map("driver_id") @db.Char(36)
  senderName       String         @map("sender_name") @db.VarChar(140)
  senderPhone      String         @map("sender_phone") @db.VarChar(40)
  pickupAddress    String         @map("pickup_address") @db.Text
  pickupContactName String        @map("pickup_contact_name") @db.VarChar(140)
  pickupContactPhone String       @map("pickup_contact_phone") @db.VarChar(40)
  dropoffAddress   String         @map("dropoff_address") @db.Text
  receiverName     String         @map("receiver_name") @db.VarChar(140)
  receiverPhone    String         @map("receiver_phone") @db.VarChar(40)
  pickupLat        Decimal        @map("pickup_lat") @db.Decimal(10, 7)
  pickupLng        Decimal        @map("pickup_lng") @db.Decimal(10, 7)
  dropoffLat       Decimal        @map("dropoff_lat") @db.Decimal(10, 7)
  dropoffLng       Decimal        @map("dropoff_lng") @db.Decimal(10, 7)
  packageWeight    Decimal        @map("package_weight") @db.Decimal(10, 2)
  packageDescription String       @map("package_description") @db.Text
  notes            String?        @db.Text
  deliveryFee      Decimal        @map("delivery_fee") @db.Decimal(10, 2)
  status           OrderStatus    @default(Pending)
  paymentStatus    PaymentStatus  @default(Pending) @map("payment_status")
  paymentMethod    PaymentMethod? @map("payment_method")
  estimatedMinutes Int?           @map("estimated_minutes")
  assignedAt       DateTime?      @map("assigned_at")
  acceptedAt       DateTime?      @map("accepted_at")
  rejectedAt       DateTime?      @map("rejected_at")
  pickedUpAt       DateTime?      @map("picked_up_at")
  deliveredAt      DateTime?      @map("delivered_at")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")
  customer         User           @relation("OrderCustomer", fields: [customerId], references: [id], onDelete: Cascade)
  driver           Driver?        @relation(fields: [driverId], references: [id], onDelete: SetNull)
  events           OrderEvent[]
  driverLocations  DriverLocation[]
  notifications    Notification[]
  payments         Payment[]

  @@index([status, createdAt], map: "idx_orders_status_created_at")
  @@index([driverId], map: "idx_orders_driver_id")
  @@index([customerId], map: "idx_orders_customer_id")
  @@index([paymentStatus], map: "idx_orders_payment_status")
  @@map("orders")
}

model OrderEvent {
  id          String   @id @db.Char(36)
  orderId     String   @map("order_id") @db.Char(36)
  eventType   String   @map("event_type") @db.VarChar(100)
  payloadJson Json     @map("payload_json")
  actorUserId String?  @map("actor_user_id") @db.Char(36)
  createdAt   DateTime @default(now()) @map("created_at")
  order       Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  actor       User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([orderId, createdAt], map: "idx_order_events_order_id_created_at")
  @@map("order_events")
}

model DriverLocation {
  id         String   @id @db.Char(36)
  driverId   String   @map("driver_id") @db.Char(36)
  orderId    String?  @map("order_id") @db.Char(36)
  latitude   Decimal  @db.Decimal(10, 7)
  longitude  Decimal  @db.Decimal(10, 7)
  recordedAt DateTime @default(now()) @map("recorded_at")
  driver     Driver   @relation(fields: [driverId], references: [id], onDelete: Cascade)
  order      Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([driverId, recordedAt], map: "idx_driver_locations_driver_id_recorded_at")
  @@map("driver_locations")
}

model Notification {
  id                String   @id @db.Char(36)
  orderId            String   @map("order_id") @db.Char(36)
  channel            String   @db.VarChar(40)
  recipient          String   @db.VarChar(255)
  status             String   @db.VarChar(40)
  providerMessageId  String?  @map("provider_message_id") @db.VarChar(255)
  createdAt          DateTime @default(now()) @map("created_at")
  order              Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model Payment {
  id                   String         @id @db.Char(36)
  orderId               String         @map("order_id") @db.Char(36)
  customerId            String         @map("customer_id") @db.Char(36)
  provider              String?        @db.VarChar(80)
  paymentMethod         PaymentMethod  @map("payment_method")
  amount                Decimal        @db.Decimal(10, 2)
  currency              String         @default("MNT") @db.VarChar(10)
  status                PaymentStatus  @default(Pending)
  transactionReference  String?        @map("transaction_reference") @db.VarChar(255)
  providerResponse      Json?          @map("provider_response")
  paidAt                DateTime?      @map("paid_at")
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @updatedAt @map("updated_at")
  order                 Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  customer              User           @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([orderId], map: "idx_payments_order_id")
  @@index([customerId], map: "idx_payments_customer_id")
  @@index([status], map: "idx_payments_status")
  @@map("payments")
}
